        },
        "security": [
          {
            "sanctum": []
          }
        ]
      },
      "patch": {
        "tags": ["Proyectos"],
        "summary": "Actualizar proyecto",
        "description": "Actualización parcial de un proyecto",
        "operationId": "c8489e0b6f426883dbfc90a81c532bb8",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "project_status_id": {
                    "type": "integer"
                  },
                  "color": {
                    "type": "string"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proyecto actualizado"
          },
          "422": {
            "description": "Transición de estado inválida"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/projects/{project}/restore": {
      "post": {
        "tags": ["Proyectos"],
        "summary": "Restaurar proyecto",
        "description": "Restaura un proyecto eliminado",
        "operationId": "7b25c2a0f064ede37cae606b0cbec69c",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Proyecto restaurado"
          },
          "422": {
            "description": "El proyecto no está eliminado"
