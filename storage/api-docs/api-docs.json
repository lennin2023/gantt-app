{
  "openapi": "3.0.0",
  "info": {
    "title": "Gantt App API",
    "description": "API REST para gestión de proyectos y tareas con diagramas Gantt",
    "contact": {
      "name": "Gantt App Team"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base URL"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Iniciar sesión",
        "description": "Valida credenciales y devuelve un token Sanctum",
        "operationId": "99d66635c4992aeaa6aa44ff653d0563",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password"
                  },
                  "device_name": {
                    "type": "string",
                    "example": "postman"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "properties": {
                        "token": {
                          "type": "string"
                        },
                        "token_type": {
                          "type": "string"
                        },
                        "user": {
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Error de validación"
          },
          "429": {
            "description": "Rate limit excedido"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Cerrar sesión",
        "description": "Revoca el token actual",
        "operationId": "6abf3b64a4bc7838d56346f05a5153af",
        "responses": {
          "200": {
            "description": "Sesión cerrada"
          },
          "401": {
            "description": "No autenticado"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/auth/logout-all": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Cerrar todas las sesiones",
        "description": "Revoca todos los tokens del usuario",
        "operationId": "8a0e47e08fb7ff4a767e76fd65943833",
        "responses": {
          "200": {
            "description": "Sesiones cerradas"
          },
          "401": {
            "description": "No autenticado"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Autenticación"],
        "summary": "Obtener usuario actual",
        "description": "Devuelve el usuario autenticado",
        "operationId": "7edae2cdbaafc10dff8c9c4198b320a2",
        "responses": {
          "200": {
            "description": "Usuario autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "role": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "No autenticado"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/dashboard/stats": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Estadísticas del dashboard",
        "description": "Métricas agregadas del usuario autenticado",
        "operationId": "06b55ec316b401263ae54a499fc977ad",
        "responses": {
          "200": {
            "description": "Estadísticas del dashboard",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "properties": {
                        "metrics": {
                          "type": "object"
                        },
                        "projects": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "No autenticado"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/projects": {
      "get": {
        "tags": ["Proyectos"],
        "summary": "Listar proyectos",
        "description": "Lista paginada de proyectos del usuario",
        "operationId": "e66a4b9c561c9e3e0b98d95b6437ff91",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "status_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de proyectos"
          },
          "401": {
            "description": "No autenticado"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      },
      "post": {
        "tags": ["Proyectos"],
        "summary": "Crear proyecto",
        "description": "Crea un nuevo proyecto (solo Admin o Super Admin)",
        "operationId": "3e5e24c249cabe95d4c10927fda15c42",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": ["company_id", "name", "color"],
                "properties": {
                  "company_id": {
                    "type": "integer"
                  },
                  "project_status_id": {
                    "type": "integer"
                  },
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string",
                    "nullable": true
                  },
                  "color": {
                    "type": "string"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Proyecto creado"
          },
          "403": {
            "description": "No autorizado"
          },
          "422": {
            "description": "Error de validación"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/projects/{project}": {
      "get": {
        "tags": ["Proyectos"],
